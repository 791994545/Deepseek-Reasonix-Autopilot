# == Reasonix 打包排除规则 ==
# 个人数据 / 运行时生成 / 敏感信息

# 会话日志（含 prompt 内容，不共享）
sessions/
*.bak

# 平台用量日志（含调用历史）
usage.jsonl

# 运行时状态（看门狗自动生成）
state.json

# 环境变量配置（含 API Key）
.env
.env.local

# 配置文件（含 API Key）
config.json

# Python 缓存
__pycache__/
*.pyc

# Git
.git/

# 备份
_backup_*/

# 系统生成
version-cache.json
